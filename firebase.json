{
  "functions": {
    "predeploy": "npm --prefix \"$RESOURCE_DIR\" run build",
    "source": "functions"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "*",
        "headers": [
          {
            "key": "Content-Security-Policy",
            "value": " default-src 'none'; connect-src https://us-central1-deep-hollow-solutions.cloudfunctions.net/sendEmail/; font-src 'self' https://fonts.gstatic.com; frame-src https://newassets.hcaptcha.com; img-src 'self'; script-src 'self' https://hcaptcha.com/1/api.js; style-src 'self' 'unsafe-inline' "
          },
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, s-maxage=31536000, immutable"
          },
          {
            "key": "X-Frame-Options",
            "value": "SAMEORIGIN"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "Referrer-Policy",
            "value": "no-referrer"
          },
          {
            "key": "x-frame-options",
            "value": "sameorigin"
          },
          {
            "key": "Permissions-Policy",
            "value": "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()"
          },
          {
            "key": "Strict-Transport-Security",
            "value": "max-age=31536000"
          }
        ]
      }
    ]
  }
}